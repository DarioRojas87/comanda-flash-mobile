{
  "expo": {
    "name": "ComandaFlash",
    "slug": "ComandaFlash-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "comandaflash",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111418"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ComandaFlash necesita tu ubicación para rastrear entregas en tiempo real.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ComandaFlash necesita tu ubicación para rastrear entregas incluso en segundo plano."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#111418"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyALG3MaisJihxZfcVHA3s_nXPewmdRttnQ"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ComandaFlash necesita tu ubicación para rastrear entregas en tiempo real.",
          "locationWhenInUsePermission": "ComandaFlash necesita tu ubicación para mostrar tu posición en el mapa."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
